{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<div class="row mb-4">
    <div class="col-12">
        <div class="bg-primary text-white p-4 rounded-3 shadow">
            <h1 class="display-4">
                <i class="bi bi-grid-3x3-gap-fill"></i>
                Dashboard
            </h1>
            <p class="lead">Bienvenue sur votre gestionnaire de tâches</p>
        </div>
    </div>
</div>

<!-- Dernières tâches -->
<div class="row">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0">
                    <i class="bi bi-clock-history"></i>
                    Dernières tâches
                </h5>
            </div>
            <div class="card-body">
                {% if latest_tasks|length > 0 %}
                    <div class="list-group">
                        {% for task in latest_tasks %}
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1 {% if task.status %}text-decoration-line-through text-muted{% endif %}">
                                        {{ task.title }}
                                    </h6>
                                    <small class="text-muted">
                                        <i class="bi bi-calendar"></i>
                                        {{ task.createdAt|date('d/m/Y H:i') }}
                                    </small>
                                </div>
                                <span class="badge {% if task.status %}bg-success{% else %}bg-warning{% endif %}">
                                    {% if task.status %}Terminée{% else %}En cours{% endif %}
                                </span>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        <p>Aucune tâche pour le moment</p>
                        <a href="{{ path('app_task_new') }}" class="btn btn-primary">
                            Créer une tâche
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
